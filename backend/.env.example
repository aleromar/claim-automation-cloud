# Copy to .env (gitignored). NON-SECRET config only — true secrets live in the
# gitignored file secret store (.secrets.json): seed it with `make seed-dev`.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
ALLOWLIST_EMAIL=operator@example.com
OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/callback
FRONTEND_BASE_URL=http://localhost:5173
SECRET_STORE_BACKEND=file
SECRET_STORE_FILE_PATH=.secrets.json
# CORS_ALLOWED_ORIGIN=https://<swa-host>   # prod only; unset in dev (Vite proxy)
